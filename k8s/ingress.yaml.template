apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: claude-code-cli-openai-api-ingress
  namespace: ${K8S_NAMESPACE}
  annotations:
    traefik.ingress.kubernetes.io/router.tls: "true"
spec:
  ingressClassName: traefik
  tls:
  - hosts:
    - ${YOUR_DOMAIN}
    secretName: ${TLS_SECRET_NAME}
  rules:
  - host: ${YOUR_DOMAIN}
    http:
      paths:
      - path: /
        pathType: Prefix
        backend:
          service:
            name: claude-code-cli-openai-api-service
            port:
              number: 80
